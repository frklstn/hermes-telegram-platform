+    def _build_browse_skills_keyboard(
+        self, items: list, page: int, total_pages: int
+    ) -> InlineKeyboardMarkup:
+        """Build inline keyboard: skill rows, navigation row."""
+        buttons = []
+        for idx, item in enumerate(items):
+            label = str(item.get("name") or "unknown")[:25]
+            buttons.append([InlineKeyboardButton(label, callback_data=f"bs:detail:{idx}")])
+        nav = []
+        if page > 0:
+            nav.append(InlineKeyboardButton("◀ Prev", callback_data="bs:page:prev"))
+        nav.append(InlineKeyboardButton(f"{page + 1}/{total_pages}", callback_data="bs:noop"))
+        if page < total_pages - 1:
+            nav.append(InlineKeyboardButton("Next ▶", callback_data="bs:page:next"))
+        if nav:
