+    async def _handle_browse_skills_callback(
+        self, query, data: str, chat_id: str
+    ) -> None:
+        """Handle bs:page or bs:detail callback."""
+        parts = data.split(":")
+        if len(parts) < 2:
+            await query.answer(text="Unknown action.")
+            return
+        verb = parts[1]
+        # Resolve actual state key by chat prefix because query is part of key.
+        state = None
+        for key, val in self._browse_skills_state.items():
+            if key.startswith(f"{chat_id}:"):
+                state = val
+                break
+        if state is None:
+            await query.answer(text="Session expired — use /browse_skills again.")
+            return
+        if verb == "noop":
+            await query.answer(text="Current page.")
+            return
+        if verb == "page":
+            direction = parts[2] if len(parts) > 2 else ""
+            page = state.get("page", 0)
+            total_pages = max(1, (len(state.get("results", [])) + self._BROWSE_SKILLS_PAGE_SIZE - 1) // self._BROWSE_SKILLS_PAGE_SIZE)
+            if direction == "prev":
+                page = max(0, page - 1)
+            elif direction == "next":
+                page = min(total_pages - 1, page + 1)
+            else:
+                try:
+                    page = max(0, min(total_pages - 1, int(direction)))
+                except ValueError:
+                    pass
+            await query.answer(text=f"Page {page + 1}")
+            await self._send_browse_skills_page(chat_id, state["query"], page, message=query.message)
+            return
+        if verb == "detail":
+            try:
+                idx = int(parts[2])
+            except (ValueError, IndexError):
+                await query.answer(text="Invalid skill.")
+                return
+            results = state.get("results", [])
+            page = state.get("page", 0)
+            start = page * self._BROWSE_SKILLS_PAGE_SIZE
+            item = results[start + idx] if 0 <= start + idx < len(results) else None
+            if not item:
+                await query.answer(text="Skill not found.")
+                return
+            name = item.get("name") or "unknown"
+            ident = item.get("identifier") or ""
+            desc = item.get("description") or "No description"
+            cat = item.get("category") or "—"
+            source = item.get("source") or "—"
+            text = (
+                f"<b>Skill:</b> <code>{_html.escape(name)}</code>\n"
+                f"<b>Identifier:</b> <code>{_html.escape(ident)}</code>\n"
+                f"<b>Category:</b> {_html.escape(cat)}\n"
+                f"<b>Source:</b> {_html.escape(source)}\n\n"
+                f"{_html.escape(desc)}"
+            )
+            await query.answer(text=name[:64])
+            try:
+                await query.edit_message_text(
+                    text=text,
+                    parse_mode=ParseMode.HTML,
+                    reply_markup=None,
+                )
+            except Exception as exc:
+                logger.warning("[Telegram] edit skill detail failed: %s", exc)
+            return
+        await query.answer(text="Unknown action.")
+
+    def _self_restart(self, script_path: Optional[str] = None) -> None:
+        """Trigger a detached gateway restart from inside the gateway process.
+
+        Hermes blocks `hermes gateway restart/stop` when invoked from within the
+        gateway process tree. We spawn a detached PowerShell process that lives
+        outside the tree and runs `hermes gateway restart --all`, which Hermes
+        allows.
+        """
+        script = script_path or r"D:\hermes-config-backup\self_restart_v3.py"
+        if not os.path.exists(script):
+            logger.warning("[Telegram] restart helper not found: %s", script)
+            return
+        try:
+            flags = subprocess.DETACHED_PROCESS | subprocess.CREATE_NEW_PROCESS_GROUP
+            subprocess.Popen(
+                [
+                    sys.executable,
+                    script,
+                    "--wait", "2",
+                ],
+                creationflags=flags,
+                close_fds=True,
+                stdout=subprocess.DEVNULL,
+                stderr=subprocess.DEVNULL,
+                stdin=subprocess.DEVNULL,
+            )
+            logger.info("[Telegram] Detached gateway restart triggered for PID %s", os.getpid())
+        except Exception as exc:
+            logger.warning("[Telegram] Failed to trigger self-restart: %s", exc)
+
